@using Final_Project_Adv.Domain.DTO
@model IEnumerable<TaskItemDto>

@{
    ViewData["Title"] = "My Tasks";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tasks = Model ?? Enumerable.Empty<TaskItemDto>();
}

@section Styles {
    <style>
        /* ── Base shell ── */
        .task-shell {
            background: #f4f6f9;
            min-height: 100vh;
            padding-bottom: 50px;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        .task-page-header {
            background: white;
            padding: 2rem 0;
            border-bottom: 1px solid #e3e6f0;
            margin-bottom: 2rem;
        }

        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .page-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1e1e2d;
            margin: 0;
        }

        .page-subtitle {
            color: #888;
            font-size: 0.9rem;
            margin-top: 5px;
        }

        /* ── Task card / table ── */
        .task-card {
            background: #fff;
            border-radius: 12px;
            border: none;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58,59,69,.1);
            overflow: hidden;
        }

        .table thead th {
            background-color: #f8f9fc;
            text-transform: uppercase;
            font-size: .75rem;
            letter-spacing: .05em;
            font-weight: 700;
            color: #4e73df;
            border-top: none;
            padding: 1rem;
        }

        .table td {
            vertical-align: middle;
            padding: 1rem;
            color: #4e4e4e;
        }

        /* ── Badges ── */
        .badge-status {
            padding: .5em .8em;
            border-radius: 6px;
            font-weight: 600;
            font-size: .8rem;
        }

        .bg-pending {
            background-color: #fff4e5;
            color: #ff9800;
        }

        .bg-progress {
            background-color: #e8f0fe;
            color: #1a73e8;
        }

        .bg-complete {
            background-color: #e6f4ea;
            color: #1e8e3e;
        }

        /* ── Action buttons ── */
        .btn-accept {
            background-color: #6c63ff;
            border: none;
            color: white;
            padding: .4rem 1rem;
            font-weight: 600;
            transition: all .2s;
        }

            .btn-accept:hover {
                background-color: #574fd6;
                transform: translateY(-1px);
            }

        .btn-subtasks {
            background-color: #fff;
            border: 1.5px solid #4e73df;
            color: #4e73df;
            padding: .35rem .85rem;
            font-size: .78rem;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            transition: all .18s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
        }

            .btn-subtasks:hover, .btn-subtasks.active {
                background-color: #4e73df;
                color: #fff;
            }

        .btn-add-subtask {
            background-color: #fff;
            border: 1.5px solid #6c63ff;
            color: #6c63ff;
            padding: .35rem .85rem;
            font-size: .78rem;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            transition: all .18s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
        }

            .btn-add-subtask:hover {
                background-color: #6c63ff;
                color: #fff;
                transform: translateY(-1px);
            }

        .btn-comment-task {
            background-color: #fff;
            border: 1.5px solid #e67e22;
            color: #e67e22;
            padding: .35rem .85rem;
            font-size: .78rem;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            transition: all .18s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
        }

            .btn-comment-task:hover {
                background-color: #e67e22;
                color: #fff;
                transform: translateY(-1px);
            }

        .btn-comment-subtask {
            background: linear-gradient(135deg,#e67e22 0%,#d35400 100%);
            border: none;
            color: #fff;
            padding: .3rem .8rem;
            font-size: .75rem;
            font-weight: 700;
            border-radius: 6px;
            cursor: pointer;
            transition: opacity .15s,transform .15s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

            .btn-comment-subtask:hover {
                opacity: .88;
                transform: translateY(-1px);
            }

        .action-cell {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        /* ── Subtask expansion panel ── */
        .subtask-panel-row td {
            padding: 0 !important;
            background: #f8f9ff;
            border-top: none;
        }

        .subtask-panel {
            display: none;
            padding: 1rem 1.5rem 1.25rem;
            border-top: 2px solid #e3e6f0;
            animation: panelSlide .2s ease;
        }

            .subtask-panel.open {
                display: block;
            }

        @@keyframes panelSlide {
            from {
                opacity: 0;
                transform: translateY(-6px);
            }

            to {
                opacity: 1;
                transform: none;
            }
        }

        .subtask-panel-title {
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .07em;
            margin-bottom: .6rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .subtask-panel-title.mine-title {
                color: #4e73df;
            }

            .subtask-panel-title.open-title {
                color: #e67e22;
            }

        .subtask-list {
            list-style: none;
            padding: 0;
            margin: 0 0 1rem;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .subtask-item {
            background: #fff;
            border: 1px solid #e3e6f0;
            border-radius: 8px;
            padding: .65rem .9rem;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .subtask-item-info {
            flex: 1;
            min-width: 0;
        }

        .subtask-item-name {
            font-weight: 600;
            font-size: .85rem;
            color: #1e1e2d;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .subtask-item-desc {
            font-size: .75rem;
            color: #888;
            margin-top: 1px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .subtask-item-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
        }

        .btn-accept-subtask {
            background: linear-gradient(135deg,#6c63ff 0%,#4e73df 100%);
            border: none;
            color: #fff;
            padding: .3rem .8rem;
            font-size: .75rem;
            font-weight: 700;
            border-radius: 6px;
            cursor: pointer;
            transition: opacity .15s,transform .15s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

            .btn-accept-subtask:hover {
                opacity: .88;
                transform: translateY(-1px);
            }

        .btn-claim-subtask {
            background: linear-gradient(135deg,#ff9800 0%,#e67e22 100%);
            border: none;
            color: #fff;
            padding: .3rem .8rem;
            font-size: .75rem;
            font-weight: 700;
            border-radius: 6px;
            cursor: pointer;
            transition: opacity .15s,transform .15s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

            .btn-claim-subtask:hover {
                opacity: .88;
                transform: translateY(-1px);
            }

        .subtask-empty {
            font-size: .82rem;
            color: #aaa;
            padding: .4rem 0;
            font-style: italic;
        }

        .subtask-loading {
            font-size: .82rem;
            color: #aaa;
            padding: .4rem 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .spin-icon {
            display: inline-block;
            animation: spin .7s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .panel-divider {
            border: none;
            border-top: 1px dashed #e3e6f0;
            margin: .75rem 0;
        }

        /* ── Add-Subtask Modal ── */
        .subtask-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 1050;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

            .subtask-modal-overlay.active {
                display: flex;
            }

        .subtask-modal {
            background: #fff;
            border-radius: 16px;
            width: 100%;
            max-width: 520px;
            box-shadow: 0 20px 60px rgba(0,0,0,.18);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: modalSlideIn .22s ease;
        }

        @@keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(18px) scale(.97);
            }

            to {
                opacity: 1;
                transform: none;
            }
        }

        .modal-header-custom {
            background: linear-gradient(135deg,#6c63ff 0%,#4e73df 100%);
            padding: 1.4rem 1.6rem;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
        }

            .modal-header-custom h5 {
                color: #fff;
                font-weight: 700;
                font-size: 1.1rem;
                margin: 0;
            }

            .modal-header-custom p {
                color: rgba(255,255,255,.75);
                font-size: .82rem;
                margin: 3px 0 0;
            }

        .modal-header-comment {
            background: linear-gradient(135deg,#e67e22 0%,#d35400 100%);
            padding: 1.4rem 1.6rem;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
        }

            .modal-header-comment h5 {
                color: #fff;
                font-weight: 700;
                font-size: 1.1rem;
                margin: 0;
            }

            .modal-header-comment p {
                color: rgba(255,255,255,.75);
                font-size: .82rem;
                margin: 3px 0 0;
            }

        .modal-close-btn {
            background: rgba(255,255,255,.2);
            border: none;
            color: #fff;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1rem;
            flex-shrink: 0;
            transition: background .15s;
        }

            .modal-close-btn:hover {
                background: rgba(255,255,255,.35);
            }

        .modal-body-custom {
            padding: 1.5rem 1.6rem;
        }

        .modal-footer-custom {
            padding: 1rem 1.6rem 1.4rem;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            border-top: 1px solid #e3e6f0;
        }

        .form-label-custom {
            font-size: .82rem;
            font-weight: 600;
            color: #4e4e6a;
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: 6px;
            display: block;
        }

        .form-control-custom, .form-select-custom {
            width: 100%;
            padding: .55rem .85rem;
            border: 1.5px solid #e3e6f0;
            border-radius: 8px;
            font-size: .9rem;
            color: #1e1e2d;
            background: #fafbff;
            transition: border-color .18s,box-shadow .18s;
            outline: none;
            font-family: inherit;
        }

            .form-control-custom:focus, .form-select-custom:focus {
                border-color: #6c63ff;
                box-shadow: 0 0 0 3px rgba(108,99,255,.12);
                background: #fff;
            }

        textarea.form-control-custom {
            resize: vertical;
            min-height: 90px;
        }

        .form-control-comment:focus {
            border-color: #e67e22 !important;
            box-shadow: 0 0 0 3px rgba(230,126,34,.15) !important;
        }

        .btn-cancel-modal {
            background: #fff;
            border: 1.5px solid #e3e6f0;
            color: #888;
            padding: .5rem 1.2rem;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
            font-family: inherit;
            font-size: .88rem;
        }

            .btn-cancel-modal:hover {
                border-color: #bbb;
                color: #555;
            }

        .btn-submit-subtask {
            background: linear-gradient(135deg,#6c63ff 0%,#4e73df 100%);
            border: none;
            color: #fff;
            padding: .5rem 1.4rem;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity .15s,transform .15s;
            font-family: inherit;
            font-size: .88rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .btn-submit-subtask:hover {
                opacity: .9;
                transform: translateY(-1px);
            }

            .btn-submit-subtask:disabled {
                opacity: .6;
                cursor: not-allowed;
                transform: none;
            }

        .btn-submit-comment {
            background: linear-gradient(135deg,#e67e22 0%,#d35400 100%);
            border: none;
            color: #fff;
            padding: .5rem 1.4rem;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity .15s,transform .15s;
            font-family: inherit;
            font-size: .88rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .btn-submit-comment:hover {
                opacity: .9;
                transform: translateY(-1px);
            }

            .btn-submit-comment:disabled {
                opacity: .6;
                cursor: not-allowed;
                transform: none;
            }

        .assign-hint {
            font-size: .78rem;
            color: #aaa;
            margin-top: 5px;
        }

        .form-group-modal {
            margin-bottom: 1.1rem;
        }

        .spinner-sm {
            width: 14px;
            height: 14px;
            border: 2px solid rgba(255,255,255,.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .6s linear infinite;
            display: none;
        }

        .loading-employees {
            font-size: .82rem;
            color: #aaa;
            padding: 6px 0;
        }
    </style>
}

<div class="task-shell">

    <!-- PAGE HEADER -->
    <div class="task-page-header">
        <div class="container header-container">
            <div>
                <h1 class="page-title">My Assignments</h1>
                <p class="page-subtitle">Manage and track your personal task queue</p>
            </div>
            <div class="text-end">
                <span class="badge bg-dark">Total: @tasks.Count()</span>
            </div>
        </div>
    </div>

    <div class="container">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- MAIN TABLE -->
        <div class="task-card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Task Details</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!tasks.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                        No tasks assigned to you yet.
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var task in tasks)
                            {
                                var statusStr = task.Status.ToString();
                                var (badgeClass, label) = statusStr switch
                                {
                                    "InProgress" => ("bg-progress", "In Progress"),
                                    "Completed" => ("bg-complete", "Completed"),
                                    _ => ("bg-pending", "Pending")
                                };

                                <!-- TASK ROW -->
                                <tr>
                                    <td class="fw-bold text-muted">#@task.Id</td>
                                    <td>
                                        <div class="fw-bold text-dark">@task.Title</div>
                                        <small class="text-muted">
                                            @(string.IsNullOrWhiteSpace(task.Description)
                                                                                ? "No description provided."
                                                                                : task.Description)
                                </small>
                            </td>
                            <td><span class="badge-status @badgeClass">@label</span></td>
                            <td class="text-muted small">@task.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-center">
                                <div class="action-cell">

                                    @if (statusStr == "Pending")
                                            {
                                                <form method="post" action="/Employee/AcceptTask">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="TaskId" value="@task.Id" />
                                                    <button type="submit" class="btn btn-sm btn-accept shadow-sm">Accept Task</button>
                                                </form>
                                            }
                                            else if (statusStr == "InProgress")
                                            {
                                                <span class="text-primary small fw-bold">
                                                    <i class="bi bi-play-circle-fill me-1"></i> Active
                                                </span>
                                                <button class="btn-add-subtask"
                                                        onclick="openSubtaskModal(@task.Id, @task.DepartmentId, '@Html.Raw(task.Title.Replace("'", "\\'"))')">
                                                    <i class="bi bi-plus-circle"></i> Add Subtask
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-success small fw-bold">
                                                    <i class="bi bi-check-all me-1"></i> Finalized
                                                </span>
                                            }

                                            <!-- View Subtasks toggle -->
                                            <button class="btn-subtasks"
                                                    id="subtask-toggle-@task.Id"
                                                    onclick="toggleSubtaskPanel(@task.Id)">
                                                <i class="bi bi-list-task"></i> Subtasks
                                            </button>

                                            <!-- NEW: Add Comment button (task level) -->
                                            <button class="btn-comment-task"
                                                    onclick="openTaskCommentModal(@task.Id, '@Html.Raw(task.Title.Replace("'", "\\'"))')">
                                                <i class="bi bi-chat-left-text"></i> Comment
                                            </button>

                                        </div>
                                    </td>
                                </tr>

                                <!-- SUBTASK EXPANSION ROW -->
                                <tr class="subtask-panel-row" id="subtask-row-@task.Id">
                                    <td colspan="5">
                                        <div class="subtask-panel" id="subtask-panel-@task.Id">
                                            <div id="subtask-loading-@task.Id" class="subtask-loading">
                                                <span class="spin-icon"><i class="bi bi-arrow-repeat"></i></span>
                                                Loading subtasks…
                                            </div>
                                            <div id="subtask-content-@task.Id" style="display:none;"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════
     ADD SUBTASK MODAL
════════════════════════════════════════════════════════════════════════════ -->
<div class="subtask-modal-overlay" id="subtaskModalOverlay" onclick="handleOverlayClick(event)">
    <div class="subtask-modal" role="dialog" aria-modal="true" aria-labelledby="subtaskModalTitle">

        <div class="modal-header-custom">
            <div>
                <h5 id="subtaskModalTitle">Add Subtask</h5>
                <p id="subtaskModalTaskName">Task: —</p>
            </div>
            <button class="modal-close-btn" onclick="closeSubtaskModal()" aria-label="Close">
                <i class="bi bi-x"></i>
            </button>
        </div>

        <form method="post" action="/Employee/CreateSubtask" id="subtaskForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="TaskItemId" id="modalTaskItemId" />
            <input type="hidden" name="DepartmentId" id="modalDepartmentId" />

            <div class="modal-body-custom">
                <div class="form-group-modal">
                    <label class="form-label-custom" for="subtaskTitle">Title <span class="text-danger">*</span></label>
                    <input type="text" id="subtaskTitle" name="Title" class="form-control-custom"
                           placeholder="e.g. Write unit tests for login module" maxlength="200" required />
                </div>
                <div class="form-group-modal">
                    <label class="form-label-custom" for="subtaskDesc">Description</label>
                    <textarea id="subtaskDesc" name="Description" class="form-control-custom"
                              placeholder="Optional — describe what needs to be done…" maxlength="2000"></textarea>
                </div>
                <div class="form-group-modal">
                    <label class="form-label-custom" for="assigneeSelect">Assign To (optional)</label>
                    <div id="employeeLoadingMsg" class="loading-employees">
                        <i class="bi bi-arrow-repeat"></i> Loading team members…
                    </div>
                    <select id="assigneeSelect" name="AssignedToId" class="form-select-custom" style="display:none;">
                        <option value="">— Leave unassigned —</option>
                    </select>
                    <p class="assign-hint">Only employees and managers in the same department are shown.</p>
                </div>
            </div>

            <div class="modal-footer-custom">
                <button type="button" class="btn-cancel-modal" onclick="closeSubtaskModal()">Cancel</button>
                <button type="submit" class="btn-submit-subtask" id="submitSubtaskBtn">
                    <span class="spinner-sm" id="submitSpinner"></span>
                    <i class="bi bi-plus-lg" id="submitIcon"></i>
                    Create Subtask
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════
     TASK COMMENT MODAL  (NEW)
════════════════════════════════════════════════════════════════════════════ -->
<div class="subtask-modal-overlay" id="taskCommentModalOverlay" onclick="handleTaskCommentOverlayClick(event)">
    <div class="subtask-modal" role="dialog" aria-modal="true" aria-labelledby="taskCommentModalTitle">

        <div class="modal-header-comment">
            <div>
                <h5 id="taskCommentModalTitle">Add Comment</h5>
                <p id="taskCommentModalTaskName">Task: —</p>
            </div>
            <button class="modal-close-btn" onclick="closeTaskCommentModal()" aria-label="Close">
                <i class="bi bi-x"></i>
            </button>
        </div>

        <form method="post" action="/Employee/PostTaskComment" id="taskCommentForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="taskItemId" id="commentTaskItemId" />

            <div class="modal-body-custom">
                <div class="form-group-modal">
                    <label class="form-label-custom" for="taskCommentContent">
                        Your Comment <span class="text-danger">*</span>
                    </label>
                    <textarea id="taskCommentContent" name="content"
                              class="form-control-custom form-control-comment"
                              placeholder="Write your comment here…"
                              maxlength="2000" required rows="4"></textarea>
                </div>
            </div>

            <div class="modal-footer-custom">
                <button type="button" class="btn-cancel-modal" onclick="closeTaskCommentModal()">Cancel</button>
                <button type="submit" class="btn-submit-comment">
                    <i class="bi bi-send"></i> Post Comment
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════
     SUBTASK COMMENT MODAL  (NEW)
════════════════════════════════════════════════════════════════════════════ -->
<div class="subtask-modal-overlay" id="subtaskCommentModalOverlay" onclick="handleSubtaskCommentOverlayClick(event)">
    <div class="subtask-modal" role="dialog" aria-modal="true" aria-labelledby="subtaskCommentModalTitle">

        <div class="modal-header-comment">
            <div>
                <h5 id="subtaskCommentModalTitle">Add Comment</h5>
                <p id="subtaskCommentModalName">Subtask: —</p>
            </div>
            <button class="modal-close-btn" onclick="closeSubtaskCommentModal()" aria-label="Close">
                <i class="bi bi-x"></i>
            </button>
        </div>

        <form method="post" action="/Employee/PostSubtaskComment" id="subtaskCommentForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="subtaskId" id="commentSubtaskId" />

            <div class="modal-body-custom">
                <div class="form-group-modal">
                    <label class="form-label-custom" for="subtaskCommentContent">
                        Your Comment <span class="text-danger">*</span>
                    </label>
                    <textarea id="subtaskCommentContent" name="content"
                              class="form-control-custom form-control-comment"
                              placeholder="Write your comment here…"
                              maxlength="2000" required rows="4"></textarea>
                </div>
            </div>

            <div class="modal-footer-custom">
                <button type="button" class="btn-cancel-modal" onclick="closeSubtaskCommentModal()">Cancel</button>
                <button type="submit" class="btn-submit-comment">
                    <i class="bi bi-send"></i> Post Comment
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Hidden CSRF form used by acceptSubtask() -->
<form id="acceptSubtaskForm" method="post" action="/Employee/AcceptSubtask" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="subtaskId" id="acceptSubtaskId" />
</form>

@section Scripts {
    <script>
        // ─────────────────────────────────────────────────────────────────────
        //  SUBTASK PANEL
        // ─────────────────────────────────────────────────────────────────────

        function statusBadge(status) {
            var map = {
                'Pending':    ['bg-pending',  'Pending'],
                'InProgress': ['bg-progress', 'In Progress'],
                'Completed':  ['bg-complete', 'Completed']
            };
            var pair = map[status] || ['bg-pending', status];
            return '<span class="badge-status ' + pair[0] + '">' + pair[1] + '</span>';
        }

        function escHtml(str) {
            return (str || '')
                .replace(/&/g, '&amp;').replace(/</g, '&lt;')
                .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function renderSubtaskItem(s, isUnassigned) {
            var btn = '';
            if (s.status === 'Pending') {
                if (isUnassigned) {
                    btn = '<button class="btn-claim-subtask" onclick="acceptSubtask(' + s.id + ')">'
                        + '<i class="bi bi-person-check-fill"></i> Claim &amp; Accept</button>';
                } else {
                    btn = '<button class="btn-accept-subtask" onclick="acceptSubtask(' + s.id + ')">'
                        + '<i class="bi bi-play-fill"></i> Accept</button>';
                }
            } else if (s.status === 'InProgress') {
                btn = '<span class="text-primary small fw-bold"><i class="bi bi-play-circle-fill me-1"></i>Active</span>';
            } else {
                btn = '<span class="text-success small fw-bold"><i class="bi bi-check-all me-1"></i>Done</span>';
            }

            // NEW: comment button for each subtask
            var commentBtn = '<button class="btn-comment-subtask" '
                + 'onclick="openSubtaskCommentModal(' + s.id + ', \'' + escHtml(s.title).replace(/'/g,"\\'") + '\')">'
                + '<i class="bi bi-chat-left-text"></i> Comment</button>';

            var desc = (s.description && s.description.trim())
                ? '<div class="subtask-item-desc">' + escHtml(s.description) + '</div>'
                : '';

            return '<li class="subtask-item">'
                + '<div class="subtask-item-info">'
                +   '<div class="subtask-item-name">' + escHtml(s.title) + '</div>'
                +   desc
                + '</div>'
                + '<div class="subtask-item-actions">'
                +   statusBadge(s.status)
                +   btn
                +   commentBtn
                + '</div>'
                + '</li>';
        }

        async function loadSubtaskPanel(taskId) {
            var loadingEl = document.getElementById('subtask-loading-' + taskId);
            var contentEl = document.getElementById('subtask-content-' + taskId);

            loadingEl.style.display = 'flex';
            contentEl.style.display = 'none';

            try {
                var resp = await fetch('/Employee/GetSubtasksForTask?taskItemId=' + taskId);
                if (!resp.ok) throw new Error('Request failed');
                var data = await resp.json();

                var html = '';

                html += '<div class="subtask-panel-title mine-title">'
                      + '<i class="bi bi-person-fill"></i> My Subtasks</div>';

                if (!data.mine || data.mine.length === 0) {
                    html += '<p class="subtask-empty">No subtasks assigned to you for this task.</p>';
                } else {
                    html += '<ul class="subtask-list">';
                    data.mine.forEach(function (s) { html += renderSubtaskItem(s, false); });
                    html += '</ul>';
                }

                if (data.unassigned && data.unassigned.length > 0) {
                    html += '<hr class="panel-divider">';
                    html += '<div class="subtask-panel-title open-title">'
                          + '<i class="bi bi-inbox-fill"></i> Open Subtasks (Unassigned)</div>';
                    html += '<ul class="subtask-list">';
                    data.unassigned.forEach(function (s) { html += renderSubtaskItem(s, true); });
                    html += '</ul>';
                }

                contentEl.innerHTML     = html;
                loadingEl.style.display = 'none';
                contentEl.style.display = 'block';
            } catch (err) {
                loadingEl.innerHTML =
                    '<span class="text-danger"><i class="bi bi-exclamation-circle"></i> Could not load subtasks.</span>';
            }
        }

        function toggleSubtaskPanel(taskId) {
            var panel     = document.getElementById('subtask-panel-' + taskId);
            var toggleBtn = document.getElementById('subtask-toggle-' + taskId);
            var isOpen    = panel.classList.contains('open');

            if (isOpen) {
                panel.classList.remove('open');
                toggleBtn.classList.remove('active');
            } else {
                panel.classList.add('open');
                toggleBtn.classList.add('active');
                loadSubtaskPanel(taskId);
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        //  ACCEPT SUBTASK
        // ─────────────────────────────────────────────────────────────────────

        function acceptSubtask(subtaskId) {
            document.getElementById('acceptSubtaskId').value = subtaskId;
            document.getElementById('acceptSubtaskForm').submit();
        }

        // ─────────────────────────────────────────────────────────────────────
        //  ADD SUBTASK MODAL
        // ─────────────────────────────────────────────────────────────────────

        async function openSubtaskModal(taskId, deptId, taskTitle) {
            document.getElementById('modalTaskItemId').value   = taskId;
            document.getElementById('modalDepartmentId').value = deptId;
            document.getElementById('subtaskModalTaskName').textContent = 'Task: ' + taskTitle;
            document.getElementById('subtaskTitle').value = '';
            document.getElementById('subtaskDesc').value  = '';
            document.getElementById('submitSubtaskBtn').disabled   = false;
            document.getElementById('submitSpinner').style.display = 'none';
            document.getElementById('submitIcon').style.display    = 'inline';
            document.getElementById('subtaskModalOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
            setTimeout(function () { document.getElementById('subtaskTitle').focus(); }, 80);
            await loadDepartmentEmployees(deptId);
        }

        function closeSubtaskModal() {
            document.getElementById('subtaskModalOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }

        function handleOverlayClick(e) {
            if (e.target === document.getElementById('subtaskModalOverlay')) closeSubtaskModal();
        }

        async function loadDepartmentEmployees(deptId) {
            var loading = document.getElementById('employeeLoadingMsg');
            var select  = document.getElementById('assigneeSelect');
            loading.innerHTML     = '<i class="bi bi-arrow-repeat"></i> Loading team members…';
            loading.style.display = 'block';
            select.style.display  = 'none';
            try {
                var resp = await fetch('/Manager/GetEmployeesByDept?deptId=' + deptId);
                if (!resp.ok) throw new Error('Status ' + resp.status);
                var employees = await resp.json();
                select.innerHTML = '<option value="">— Leave unassigned —</option>';
                employees.forEach(function (emp) {
                    var opt = document.createElement('option');
                    opt.value       = emp.id;
                    opt.textContent = emp.username + ' (' + emp.role + ')';
                    select.appendChild(opt);
                });
                loading.style.display = 'none';
                select.style.display  = 'block';
            } catch (err) {
                loading.innerHTML =
                    '<span class="text-danger"><i class="bi bi-exclamation-circle"></i> Could not load team members.</span>';
            }
        }

        document.getElementById('subtaskForm').addEventListener('submit', function () {
            var btn     = document.getElementById('submitSubtaskBtn');
            var spinner = document.getElementById('submitSpinner');
            var icon    = document.getElementById('submitIcon');
            btn.disabled          = true;
            spinner.style.display = 'inline-block';
            icon.style.display    = 'none';
        });

        // ─────────────────────────────────────────────────────────────────────
        //  TASK COMMENT MODAL  (NEW)
        // ─────────────────────────────────────────────────────────────────────

        function openTaskCommentModal(taskId, taskTitle) {
            document.getElementById('commentTaskItemId').value = taskId;
            document.getElementById('taskCommentModalTaskName').textContent = 'Task: ' + taskTitle;
            document.getElementById('taskCommentContent').value = '';
            document.getElementById('taskCommentModalOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
            setTimeout(function () { document.getElementById('taskCommentContent').focus(); }, 80);
        }

        function closeTaskCommentModal() {
            document.getElementById('taskCommentModalOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }

        function handleTaskCommentOverlayClick(e) {
            if (e.target === document.getElementById('taskCommentModalOverlay')) closeTaskCommentModal();
        }

        // ─────────────────────────────────────────────────────────────────────
        //  SUBTASK COMMENT MODAL  (NEW)
        // ─────────────────────────────────────────────────────────────────────

        function openSubtaskCommentModal(subtaskId, subtaskTitle) {
            document.getElementById('commentSubtaskId').value = subtaskId;
            document.getElementById('subtaskCommentModalName').textContent = 'Subtask: ' + subtaskTitle;
            document.getElementById('subtaskCommentContent').value = '';
            document.getElementById('subtaskCommentModalOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
            setTimeout(function () { document.getElementById('subtaskCommentContent').focus(); }, 80);
        }

        function closeSubtaskCommentModal() {
            document.getElementById('subtaskCommentModalOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }

        function handleSubtaskCommentOverlayClick(e) {
            if (e.target === document.getElementById('subtaskCommentModalOverlay')) closeSubtaskCommentModal();
        }

        // Global Escape key handler — closes whichever modal is open
        document.addEventListener('keydown', function (e) {
            if (e.key !== 'Escape') return;
            closeSubtaskModal();
            closeTaskCommentModal();
            closeSubtaskCommentModal();
        });
    </script>
}