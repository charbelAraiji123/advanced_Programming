@model List<Final_Project_Adv.Domain.DTO.AuditLogDto>

@{
    ViewData["Title"] = "Audit Logs";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int totalCount = ViewBag.TotalCount;
    string? search = ViewBag.Search;
    string? fAction = ViewBag.FilterAction;
    string? fEntity = ViewBag.FilterEntity;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --primary: #4f46e5;
        --primary-hover: #4338ca;
        --bg: #f8fafc;
        --text: #1e293b;
        --muted: #64748b;
        --border: #e2e8f0;
        --radius: 10px;
    }

    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
    }

    .page-wrap {
        padding: 36px 28px;
        background: var(--bg);
        min-height: 100vh;
        color: var(--text);
    }

    /* ── Header ── */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 28px;
    }

        .page-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin: 0 0 4px;
        }

        .page-header p {
            color: var(--muted);
            margin: 0;
            font-size: 0.9rem;
        }

    .badge-count {
        background: #eef2ff;
        color: var(--primary);
        font-size: 0.8rem;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 20px;
        white-space: nowrap;
        align-self: center;
    }

    /* ── Filter bar ── */
    .filter-bar {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 18px 20px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: flex-end;
        margin-bottom: 24px;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
        flex: 1;
        min-width: 160px;
    }

        .filter-group label {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .filter-group input,
        .filter-group select {
            padding: 9px 12px;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-size: 0.9rem;
            color: var(--text);
            background: #fff;
            outline: none;
            transition: border-color 0.2s;
        }

            .filter-group input:focus,
            .filter-group select:focus {
                border-color: var(--primary);
            }

    .btn-filter {
        padding: 9px 20px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 7px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: background 0.2s;
        white-space: nowrap;
        align-self: flex-end;
    }

        .btn-filter:hover {
            background: var(--primary-hover);
        }

    .btn-clear {
        padding: 9px 16px;
        background: white;
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: all 0.2s;
        align-self: flex-end;
    }

        .btn-clear:hover {
            background: #f1f5f9;
            color: var(--text);
        }

    /* ── Table card ── */
    .table-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .audit-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

        .audit-table thead {
            background: #f8fafc;
            border-bottom: 1px solid var(--border);
        }

        .audit-table th {
            padding: 12px 16px;
            text-align: left;
            font-weight: 600;
            color: var(--muted);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            white-space: nowrap;
        }

        .audit-table td {
            padding: 13px 16px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .audit-table tbody tr:last-child td {
            border-bottom: none;
        }

        .audit-table tbody tr:hover {
            background: #fafafa;
        }

    /* ── Action badge ── */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .badge-created {
        background: #dcfce7;
        color: #15803d;
    }

    .badge-updated {
        background: #fef9c3;
        color: #a16207;
    }

    .badge-deleted {
        background: #fee2e2;
        color: #b91c1c;
    }

    .badge-default {
        background: #e0e7ff;
        color: #4338ca;
    }

    /* ── JSON toggle ── */
    .json-toggle {
        background: none;
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .json-toggle:hover {
            background: #f1f5f9;
            color: var(--text);
        }

    .json-panel {
        display: none;
        margin-top: 8px;
        background: #1e293b;
        color: #94a3b8;
        border-radius: 6px;
        padding: 10px 12px;
        font-family: monospace;
        font-size: 0.78rem;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-all;
        max-height: 160px;
        overflow-y: auto;
    }

        .json-panel.open {
            display: block;
        }

    /* ── Empty state ── */
    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 2.5rem;
            margin-bottom: 16px;
            opacity: 0.35;
        }

        .empty-state p {
            font-size: 0.95rem;
            margin: 0;
        }

    /* ── Pagination ── */
    .pagination-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        padding: 16px 20px;
        border-top: 1px solid var(--border);
        background: #fafafa;
    }

    .pagination-info {
        font-size: 0.85rem;
        color: var(--muted);
    }

    .pagination-btns {
        display: flex;
        gap: 6px;
    }

    .page-btn {
        padding: 7px 13px;
        border: 1px solid var(--border);
        background: white;
        color: var(--text);
        border-radius: 7px;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .page-btn:hover:not(.disabled) {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .page-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .page-btn.disabled {
            opacity: 0.4;
            pointer-events: none;
        }

    /* ── Back link ── */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--muted);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.9rem;
        margin-top: 28px;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: var(--primary);
        }

    /* ── Alert ── */
    .alert-info {
        background: #eef2ff;
        color: #3730a3;
        border: 1px solid #c7d2fe;
        border-radius: var(--radius);
        padding: 14px 18px;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }
</style>

<div class="page-wrap">

    <!-- Header -->
    <div class="page-header">
        <div>
            <h1><i class="fa-solid fa-clock-rotate-left" style="color:var(--primary);margin-right:10px;"></i>Audit Logs</h1>
            <p>Full history of admin actions — creates, updates, and deletes.</p>
        </div>
        <span class="badge-count"><i class="fa-solid fa-database"></i> @totalCount record@(totalCount != 1 ? "s" : "")</span>
    </div>

    <!-- Active filter notice -->
    @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(fAction) || !string.IsNullOrEmpty(fEntity))
    {
        <div class="alert-info">
            <i class="fa-solid fa-filter"></i>
            Filters active — showing @Model.Count of @totalCount matching records.
        </div>
    }

    <!-- Filter bar -->
    <form method="get" action="/Admin/AuditLogs" class="filter-bar">
        <div class="filter-group" style="flex:2;min-width:200px;">
            <label>Search</label>
            <input type="text" name="search" value="@search" placeholder="Username, entity, or action…">
        </div>

        <div class="filter-group">
            <label>Action</label>
            <select name="filterAction">
                <option value="">All actions</option>
                @foreach (var action in (List<string>)ViewBag.Actions)
                {
                    <option value="@action" selected="@(fAction == action ? "selected" : null)">@action</option>
                }
            </select>
        </div>

        <div class="filter-group">
            <label>Entity</label>
            <select name="filterEntity">
                <option value="">All entities</option>
                @foreach (var entity in (List<string>)ViewBag.Entities)
                {
                    <option value="@entity" selected="@(fEntity == entity ? "selected" : null)">@entity</option>
                }
            </select>
        </div>

        <button type="submit" class="btn-filter">
            <i class="fa-solid fa-magnifying-glass"></i> Filter
        </button>

        <a href="/Admin/AuditLogs" class="btn-clear">
            <i class="fa-solid fa-xmark"></i> Clear
        </a>
    </form>

    <!-- Table -->
    <div class="table-card">
        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <i class="fa-solid fa-inbox"></i>
                <p>No audit log entries found.</p>
            </div>
        }
        else
        {
            <table class="audit-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Timestamp</th>
                        <th>Admin</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Entity ID</th>
                        <th>Old Value</th>
                        <th>New Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td style="color:var(--muted);font-size:0.8rem;">@log.Id</td>

                            <td style="white-space:nowrap;">
                                <div style="font-weight:500;">@log.PerformedAt.ToString("MMM dd, yyyy")</div>
                                <div style="color:var(--muted);font-size:0.78rem;">@log.PerformedAt.ToString("HH:mm:ss") UTC</div>
                            </td>

                            <td>
                                <div style="display:flex;align-items:center;gap:8px;">
                                    <div style="width:30px;height:30px;border-radius:50%;background:#eef2ff;display:flex;align-items:center;justify-content:center;color:var(--primary);font-weight:600;font-size:0.8rem;flex-shrink:0;">
                                        @log.PerformedBy.Substring(0, 1).ToUpper()
                                    </div>
                                    <span style="font-weight:500;">@log.PerformedBy</span>
                                </div>
                            </td>

                            <td>
                                @{
                                    var badgeClass = log.Action switch
                                    {
                                        "Created" => "badge-created",
                                        "Updated" => "badge-updated",
                                        "Deleted" => "badge-deleted",
                                        _ => "badge-default"
                                    };
                                    var badgeIcon = log.Action switch
                                    {
                                        "Created" => "fa-plus",
                                        "Updated" => "fa-pen",
                                        "Deleted" => "fa-trash",
                                        _ => "fa-circle"
                                    };
                                }
                                <span class="badge @badgeClass">
                                    <i class="fa-solid @badgeIcon" style="font-size:0.65rem;"></i>
                                    @log.Action
                                </span>
                            </td>

                            <td style="font-weight:500;">@log.EntityType</td>

                            <td>
                                <span style="background:#f1f5f9;padding:3px 8px;border-radius:5px;font-size:0.8rem;font-family:monospace;">
                                    #@log.EntityId
                                </span>
                            </td>

                            <!-- Old Value -->
                            <td>
                                @if (!string.IsNullOrEmpty(log.OldValue))
                                {
                                    var oldId = $"old-{log.Id}";
                                    <button class="json-toggle" onclick="toggleJson('@oldId')">
                                        <i class="fa-solid fa-eye"></i> View
                                    </button>
                                    <div id="@oldId" class="json-panel">@log.OldValue</div>
                                }
                                else
                                {
                                    <span style="color:var(--muted);font-size:0.8rem;">—</span>
                                }
                            </td>

                            <!-- New Value -->
                            <td>
                                @if (!string.IsNullOrEmpty(log.NewValue))
                                {
                                    var newId = $"new-{log.Id}";
                                    <button class="json-toggle" onclick="toggleJson('@newId')">
                                        <i class="fa-solid fa-eye"></i> View
                                    </button>
                                    <div id="@newId" class="json-panel">@log.NewValue</div>
                                }
                                else
                                {
                                    <span style="color:var(--muted);font-size:0.8rem;">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            <div class="pagination-bar">
                <span class="pagination-info">
                    Page @currentPage of @totalPages
                </span>
                <div class="pagination-btns">
                    <a class="page-btn @(currentPage <= 1 ? "disabled" : "")"
                       href="/Admin/AuditLogs?page=@(currentPage - 1)&search=@search&filterAction=@fAction&filterEntity=@fEntity">
                        <i class="fa-solid fa-chevron-left"></i> Prev
                    </a>

                    @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                    {
                        <a class="page-btn @(p == currentPage ? "active" : "")"
                           href="/Admin/AuditLogs?page=@p&search=@search&filterAction=@fAction&filterEntity=@fEntity">
                            @p
                        </a>
                    }

                    <a class="page-btn @(currentPage >= totalPages ? "disabled" : "")"
                       href="/Admin/AuditLogs?page=@(currentPage + 1)&search=@search&filterAction=@fAction&filterEntity=@fEntity">
                        Next <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </div>
            </div>
        }
    </div>

    <a href="/Admin/Panel" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Back to Admin Panel
    </a>
</div>

<script>
    function toggleJson(id) {
        const panel = document.getElementById(id);
        panel.classList.toggle('open');

        // Pretty-print JSON if not already done
        if (panel.classList.contains('open') && !panel.dataset.formatted) {
            try {
                const parsed = JSON.parse(panel.textContent);
                panel.textContent = JSON.stringify(parsed, null, 2);
                panel.dataset.formatted = '1';
            } catch (_) { /* not valid JSON, show raw */ }
        }
    }
</script>