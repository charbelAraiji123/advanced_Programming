@{
    ViewData["Title"] = "User Management";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --primary: #4f46e5;
        --primary-hover: #4338ca;
        --danger: #ef4444;
        --success: #10b981;
        --bg-main: #f8fafc;
        --text-dark: #1e293b;
        --text-muted: #64748b;
    }

    body {
        background-color: var(--bg-main);
        font-family: 'Inter', sans-serif;
        color: var(--text-dark);
    }

    /* Breadcrumb Styling */
    .breadcrumb {
        background: transparent;
        padding: 0;
        margin-bottom: 20px;
    }

    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
        font-weight: 500;
    }

    /* Card & Header */
    .management-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .card-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Action Bar Styling */
    .action-bar {
        display: flex;
        gap: 10px;
        padding: 15px 24px;
        background: #fdfdfd;
        border-bottom: 1px solid #f1f5f9;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 8px;
        transition: all 0.2s;
        border: 1px solid #e2e8f0;
        background: white;
        color: var(--text-dark);
        text-decoration: none;
    }

        .btn-action:hover {
            background: #f8fafc;
            border-color: var(--primary);
            color: var(--primary);
            transform: translateY(-1px);
        }

    .btn-create {
        background: var(--primary);
        color: white !important;
        border-color: var(--primary);
    }

        .btn-create:hover {
            background: var(--primary-hover);
        }

    /* Table Styling */
    .table-container {
        padding: 0 24px 24px 24px;
    }

    .table {
        margin-bottom: 0;
        vertical-align: middle;
    }

        .table thead th {
            background: #f8fafc;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            font-weight: 600;
            color: var(--text-muted);
            border-top: none;
            padding: 16px;
        }

        .table tbody tr {
            transition: background 0.2s;
        }

            .table tbody tr:hover {
                background-color: #f1f5f9;
            }

        .table td {
            padding: 16px;
            border-color: #f1f5f9;
        }

    .user-name {
        font-weight: 600;
        color: var(--text-dark);
    }

    .user-email {
        color: var(--text-muted);
        font-size: 0.875rem;
    }

    /* Row Actions */
    .row-btn {
        padding: 6px 12px;
        font-size: 0.8rem;
        border-radius: 6px;
        margin-right: 4px;
    }

    .status-badge {
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        background: #ecfdf5;
        color: var(--success);
    }
</style>

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="AdminView" asp-action="AdminPanel">
                    <i class="fa-solid fa-house-gear me-1"></i> Admin Control
                </a>
            </li>
            <li class="breadcrumb-item active">User Management</li>
        </ol>
    </nav>

    <div class="management-card">
        <div class="card-header-flex">
            <h2 class="h4 fw-bold mb-0">User Directory</h2>
            <span class="badge bg-light text-dark border">Total Users: <span id="userCount">0</span></span>
        </div>

        <!-- Unified Action Bar -->
        <div class="action-bar">
            <form action="/Admin/CreateUser" method="get">
                <button type="submit" class="btn-action btn-create">
                    <i class="fa-solid fa-plus"></i> Create User
                </button>
            </form>

            <form action="/Admin/UpdateUser" method="get">
                <button type="submit" class="btn-action">
                    <i class="fa-solid fa-pen-to-square"></i> Bulk Update
                </button>
            </form>

            <form action="/Admin/DeleteManagement" method="get">
                <button type="submit" class="btn-action text-danger">
                    <i class="fa-solid fa-trash-can"></i> Delete Mode
                </button>
            </form>
        </div>

        <div class="table-container">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>User Details</th>
                            <th>Email Address</th>
                            <th>Status</th>
                            <th class="text-end">Quick Actions</th>
                        </tr>
                    </thead>
                    <tbody id="userTable">
                        <!-- Placeholder for JS Loading -->
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-circle-notch fa-spin me-2"></i> Fetching system users...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>