@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-5">
    <!-- Breadcrumb for navigation -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="AdminView" asp-action="AdminPanel" class="text-decoration-none">Admin Control</a></li>
            <li class="breadcrumb-item active fw-bold">Departement Management</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Management Panel matching your reference image -->
            <div class="card shadow-sm border-secondary-subtle" style="border-radius: 16px; padding: 2rem;">
                <div class="card-body text-center d-flex flex-column align-items-center">

                    <h1 class="fw-bold mb-3" style="font-size: 2.2rem; color: #000;">User Management</h1>

                    <p class="text-muted mb-4" style="font-size: 1.1rem; max-width: 300px;">
                        Create, update, or remove users from the system.
                    </p>

                    <!-- This button will eventually trigger a modal or a list view -->
                    <button id="btnManage" class="btn btn-light border w-100 py-3 text-secondary fw-bold shadow-sm"
                            style="background-color: #f8f9fa; font-size: 1.1rem;">
                        Create Users
                    </button>
                    <button id="btnManage" class="btn btn-light border w-100 py-3 text-secondary fw-bold shadow-sm"
                            style="background-color: #f8f9fa; font-size: 1.1rem;">
                        Modify Users
                    </button>
                    <button id="btnManage" class="btn btn-light border w-100 py-3 text-secondary fw-bold shadow-sm"
                            style="background-color: #f8f9fa; font-size: 1.1rem;">
                        Delete Users
                    </button>


                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="AdminView" asp-action="AdminPanel" class="btn btn-link text-muted text-decoration-none">
                    <i class="fas fa-arrow-left me-1"></i> Return to Admin Grid
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Placeholder for future logic to load user list via your API
        document.getElementById('btnManage').addEventListener('click', function() {
            console.log("Loading users from api/Admin/Users...");
            // You can add logic here to show a table or redirect to a detailed list
        });
    </script>
}