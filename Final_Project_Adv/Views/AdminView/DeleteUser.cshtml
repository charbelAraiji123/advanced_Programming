<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm p-4 border-danger" style="border-radius: 15px;">
                <h2 class="fw-bold text-center text-danger">Delete User</h2>
                <p class="text-center">Search for a user to remove from the system.</p>
                <div class="mb-3">
                    <input type="number" id="deleteId" class="form-control" placeholder="Enter User ID to delete">
                </div>
                <button class="btn btn-danger w-100 py-2">Confirm Delete</button>
                <a asp-action="UserManagement" class="btn btn-link w-100 mt-2 text-muted">Cancel</a>
            </div>
        </div>
    </div>
</div>