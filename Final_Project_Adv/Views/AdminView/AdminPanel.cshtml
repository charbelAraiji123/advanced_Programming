@{
    ViewData["Title"] = "Admin Control Panel";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --primary-color: #4f46e5;
        --primary-hover: #4338ca;
        --bg-subtle: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --card-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --card-shadow-hover: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
    }

    .admin-container {
        font-family: 'Inter', sans-serif;
        padding: 40px 20px;
        background-color: var(--bg-subtle);
        min-height: 100vh;
        color: var(--text-main);
    }

    .panel-header {
        margin-bottom: 40px;
        text-align: left;
    }

        .panel-header h1 {
            font-weight: 700;
            letter-spacing: -0.025em;
            margin-bottom: 8px;
        }

    .admin-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 24px;
    }

    .admin-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 30px 24px;
        text-align: left;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

        .admin-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--primary-color);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .admin-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--card-shadow-hover);
            border-color: transparent;
        }

            .admin-card:hover::before {
                opacity: 1;
            }

    .icon-wrapper {
        width: 48px;
        height: 48px;
        background: #eef2ff;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        color: var(--primary-color);
        font-size: 1.25rem;
        transition: background 0.3s;
    }

    .admin-card:hover .icon-wrapper {
        background: var(--primary-color);
        color: white;
    }

    .admin-card h3 {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: 12px;
    }

    .admin-card p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 20px;
        flex-grow: 1;
    }

    .btn-admin {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: var(--text-main);
        font-weight: 500;
        padding: 10px 16px;
        border-radius: 8px;
        transition: all 0.2s;
        text-align: center;
        width: 100%;
        text-decoration: none;
        display: inline-block;
    }

        .btn-admin:hover:not(:disabled) {
            background-color: var(--primary-color);
            color: white;
            border-color: var(--primary-color);
        }

        .btn-admin:disabled {
            background-color: #f1f5f9;
            color: #94a3b8;
            cursor: not-allowed;
            border-color: #e2e8f0;
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: var(--primary-color);
        }
</style>

<div class="admin-container">
    <div class="panel-header">
        <h1>Admin System Control</h1>
        <p class="text-muted">Manage your organization's infrastructure and security settings.</p>
    </div>

    <div class="admin-grid">
        <!-- User Management -->
        <div class="admin-card">
            <div class="icon-wrapper"><i class="fa-solid fa-users"></i></div>
            <h3>User Management</h3>
            <p>Create, update, or remove users and manage their profile details.</p>
            <form action="/Admin/UserManagement" method="get">
                <button type="submit" class="btn-admin">Manage Users</button>
            </form>
        </div>

        <!-- Department Management -->
        <div class="admin-card">
            <div class="icon-wrapper"><i class="fa-solid fa-sitemap"></i></div>
            <h3>Departments</h3>
            <p>Configure organizational units and assign department heads.</p>
            <button class="btn-admin" disabled title="Coming Soon">Manage Depts</button>
        </div>

        <!-- Permission Control -->
        <div class="admin-card">
            <div class="icon-wrapper"><i class="fa-solid fa-shield-halved"></i></div>
            <h3>Permissions</h3>
            <p>Fine-tune RBAC settings and grant specific action rights to roles.</p>
            <form action="/Admin/Permissions" method="get">
                <button type="submit" class="btn-admin">Role Access</button>
            </form>
        </div>

        <!-- Audit Logs ✅ NOW LINKED -->
        <div class="admin-card">
            <div class="icon-wrapper"><i class="fa-solid fa-clock-rotate-left"></i></div>
            <h3>Audit Logs</h3>
            <p>Review system-wide changes, logins, and admin activity logs.</p>
            <form action="/Admin/AuditLogs" method="get">
                <button type="submit" class="btn-admin">View Logs</button>
            </form>
        </div>

        <!-- System Settings -->
        <div class="admin-card">
            <div class="icon-wrapper"><i class="fa-solid fa-gears"></i></div>
            <h3>System Settings</h3>
            <p>Modify global variables, SMTP settings, and JWT configurations.</p>
            <button class="btn-admin" disabled>Configure</button>
        </div>
    </div>

    <div class="mt-5">
        <a href="/" class="back-link">
            <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>