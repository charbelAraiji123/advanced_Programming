@using Final_Project_Adv.Domain.DTO
@model Final_Project_Adv.Models.TaskDashboardVm

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tasks = Model?.Tasks ?? new List<TaskDashboardItemDto>();
    var total = tasks.Count;
    var inProgress = tasks.Count(t => t.Status.ToString() == "InProgress");
    var completed = tasks.Count(t => t.Status.ToString() == "Completed");
    var pending = tasks.Count(t => t.Status.ToString() == "Pending");
}

@section Styles {
    <style>
        .db-shell {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        /* ── Topbar ── */
        .db-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            height: 60px;
            background: #1e1e2d;
            color: #fff;
        }

        .db-topbar-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .db-logo-mark {
            background: #6c63ff;
            color: #fff;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 14px;
        }

        .db-logo-text {
            font-size: 18px;
            font-weight: 600;
            color: #fff;
        }

        .db-nav {
            display: flex;
            gap: 24px;
            align-items: center;
        }

        .db-nav-link {
            color: #aaa;
            text-decoration: none;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 4px 0;
            border-bottom: 2px solid transparent;
            transition: color .2s,border-color .2s;
        }

            .db-nav-link.active, .db-nav-link:hover {
                color: #fff;
            }

            .db-nav-link.active {
                border-bottom-color: #6c63ff;
            }

        .db-btn-primary {
            background: #6c63ff;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background .2s;
        }

            .db-btn-primary:hover {
                background: #574fd6;
                color: #fff;
            }

        .db-btn-ghost {
            background: transparent;
            color: #aaa;
            border: 1px solid #3a3a4e;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all .2s;
        }

            .db-btn-ghost:hover {
                background: #2a2a3d;
                color: #fff;
                border-color: #6c63ff;
            }

        .db-topbar-right {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        /* ── View Subtasks button ── */
        .btn-view-subtasks {
            background: #fff;
            border: 1.5px solid #6c63ff;
            color: #6c63ff;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: all .18s;
            white-space: nowrap;
            font-family: inherit;
        }

            .btn-view-subtasks:hover {
                background: #6c63ff;
                color: #fff;
            }

        /* NEW ── View Comments button ── */
        .btn-view-comments {
            background: #fff;
            border: 1.5px solid #e67e22;
            color: #e67e22;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: all .18s;
            white-space: nowrap;
            font-family: inherit;
        }

            .btn-view-comments:hover {
                background: #e67e22;
                color: #fff;
            }

        /* NEW ── Subtask comments button (inside drawer) ── */
        .btn-subtask-comments {
            background: #fff3e0;
            border: 1px solid #e67e22;
            color: #d35400;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transition: all .15s;
            white-space: nowrap;
            font-family: inherit;
        }

            .btn-subtask-comments:hover {
                background: #e67e22;
                color: #fff;
            }

        /* ── Main ── */
        .db-main {
            padding: 32px;
        }

        .db-page-head {
            margin-bottom: 24px;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .db-page-title {
            font-size: 24px;
            font-weight: 700;
            color: #1e1e2d;
            margin: 0;
        }

        .db-page-sub {
            color: #888;
            font-size: 14px;
            margin: 4px 0 0;
        }

        /* ── Stat cards ── */
        .db-stats {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 16px;
            margin-bottom: 32px;
        }

        .db-stat-card {
            background: #fff;
            border-radius: 10px;
            padding: 20px 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,.08);
            border-left: 4px solid transparent;
        }

            .db-stat-card.total {
                border-left-color: #6c63ff;
            }

            .db-stat-card.inprogress {
                border-left-color: #3b82f6;
            }

            .db-stat-card.completed {
                border-left-color: #10b981;
            }

            .db-stat-card.pending {
                border-left-color: #f59e0b;
            }

        .db-stat-value {
            font-size: 32px;
            font-weight: 700;
            color: #1e1e2d;
        }

        .db-stat-label {
            font-size: 13px;
            color: #888;
            margin-top: 4px;
        }

        /* ── Table ── */
        .db-table-wrap {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0,0,0,.08);
            padding: 24px;
        }

        .db-table-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .db-section-title {
            font-size: 16px;
            font-weight: 600;
            color: #1e1e2d;
            margin: 0;
        }

        .db-task-count {
            font-size: 13px;
            color: #888;
            background: #f0f0f0;
            padding: 3px 10px;
            border-radius: 20px;
        }

        .db-search {
            padding: 7px 14px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 13px;
            outline: none;
            width: 220px;
            transition: border-color .2s;
        }

            .db-search:focus {
                border-color: #6c63ff;
            }

        .db-table-scroll {
            overflow-x: auto;
        }

        .db-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

            .db-table thead tr {
                background: #f8f8fb;
            }

            .db-table th {
                padding: 12px 16px;
                text-align: left;
                font-weight: 600;
                color: #555;
                border-bottom: 1px solid #eee;
                white-space: nowrap;
            }

            .db-table td {
                padding: 12px 16px;
                color: #333;
                border-bottom: 1px solid #f0f0f0;
            }

            .db-table tbody tr:hover {
                background: #fafafa;
            }

        .db-badge {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-pending {
            background: #fef9c3;
            color: #a16207;
        }

        .badge-inprogress {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .badge-completed {
            background: #dcfce7;
            color: #15803d;
        }

        .success-banner {
            background: #dcfce7;
            color: #15803d;
            border: 1px solid #bbf7d0;
            border-radius: 8px;
            padding: 12px 20px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .error-banner {
            background: #fef2f2;
            color: #b91c1c;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 12px 20px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 500;
        }

        .db-empty {
            text-align: center;
            color: #aaa;
            padding: 32px 0;
            font-size: 14px;
        }

        /* ── Shared drawer base ── */
        .drawer-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.35);
            z-index: 900;
        }

            .drawer-overlay.open {
                display: block;
            }

        .side-drawer {
            position: fixed;
            top: 0;
            right: 0;
            height: 100vh;
            width: 420px;
            max-width: 95vw;
            background: #fff;
            box-shadow: -6px 0 32px rgba(0,0,0,.14);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transform: translateX(100%);
            transition: transform .28s cubic-bezier(.4,0,.2,1);
        }

            .side-drawer.open {
                transform: translateX(0);
            }

        /* ── Subtask drawer head ── */
        .drawer-head {
            background: linear-gradient(135deg,#6c63ff 0%,#4e73df 100%);
            padding: 20px 24px;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-shrink: 0;
        }
        /* ── Comment drawer head ── */
        .drawer-head-comment {
            background: linear-gradient(135deg,#e67e22 0%,#d35400 100%);
            padding: 20px 24px;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .drawer-head-title {
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            margin: 0;
        }

        .drawer-head-sub {
            color: rgba(255,255,255,.7);
            font-size: 12px;
            margin-top: 3px;
        }

        .drawer-close {
            background: rgba(255,255,255,.2);
            border: none;
            color: #fff;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: background .15s;
            line-height: 1;
        }

            .drawer-close:hover {
                background: rgba(255,255,255,.35);
            }

        .drawer-body {
            flex: 1;
            overflow-y: auto;
            padding: 20px 24px;
        }

            .drawer-body::-webkit-scrollbar {
                width: 5px;
            }

            .drawer-body::-webkit-scrollbar-track {
                background: transparent;
            }

            .drawer-body::-webkit-scrollbar-thumb {
                background: #e0e0e0;
                border-radius: 99px;
            }

        /* ── Subtask card (inside subtask drawer) ── */
        .subtask-item {
            background: #f8f9fc;
            border: 1px solid #e8ecf4;
            border-radius: 10px;
            padding: 14px 16px;
            margin-bottom: 10px;
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .subtask-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
            flex-shrink: 0;
            margin-top: 5px;
        }

        .dot-pending {
            background: #f59e0b;
        }

        .dot-inprogress {
            background: #3b82f6;
        }

        .dot-completed {
            background: #10b981;
        }

        .subtask-info {
            flex: 1;
            min-width: 0;
        }

        .subtask-title {
            font-size: 14px;
            font-weight: 600;
            color: #1e1e2d;
            margin-bottom: 3px;
            word-break: break-word;
        }

        .subtask-desc {
            font-size: 12px;
            color: #888;
            margin-bottom: 6px;
            word-break: break-word;
        }

        .subtask-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            align-items: center;
        }

        .subtask-badge {
            font-size: 11px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 20px;
        }

        .sb-pending {
            background: #fef9c3;
            color: #a16207;
        }

        .sb-inprogress {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .sb-completed {
            background: #dcfce7;
            color: #15803d;
        }

        .subtask-assignee {
            font-size: 11px;
            color: #888;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* ── Comment card (inside comment drawer) ── */
        .comment-card {
            background: #fff8f3;
            border: 1px solid #fde8d3;
            border-radius: 10px;
            padding: 14px 16px;
            margin-bottom: 10px;
        }

        .comment-author {
            font-size: 13px;
            font-weight: 700;
            color: #d35400;
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .comment-body {
            font-size: 14px;
            color: #333;
            line-height: 1.55;
            word-break: break-word;
        }

        .comment-time {
            font-size: 11px;
            color: #aaa;
            margin-top: 6px;
        }

        /* ── Drawer states (loading / empty / error) ── */
        .drawer-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 16px;
            color: #aaa;
            font-size: 14px;
            gap: 10px;
            text-align: center;
        }

        .drawer-state-icon {
            font-size: 32px;
            opacity: .4;
        }

        .spin-ring {
            width: 28px;
            height: 28px;
            border: 3px solid #e0e0e0;
            border-top-color: #6c63ff;
            border-radius: 50%;
            animation: rotate .7s linear infinite;
        }

        .spin-ring-orange {
            border-top-color: #e67e22;
        }

        @@keyframes rotate {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
}

<div class="db-shell">

    <!-- TOPBAR -->
    <header class="db-topbar">
        <div class="db-topbar-left">
            <span class="db-logo-mark">TM</span>
            <span class="db-logo-text">TaskFlow</span>
        </div>

        <nav class="db-nav">
            <a href="/Manager/Dashboard" class="db-nav-link active">&#9632; Dashboard</a>
            <a href="/Manager/Progress" class="db-nav-link">&#9650; Team Progress</a>
        </nav>

        <div class="db-topbar-right">
            <a href="/Manager/UpdateTask" class="db-btn-ghost">&#9998; Update Task</a>
            <a href="/Manager/CreateTask" class="db-btn-primary">&#43; New Task</a>
            <form action="/Account/Logout" method="post" style="display:inline;margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" class="db-btn-ghost" style="color:#f87171;border-color:#f87171;">
                    &#x2192; Logout
                </button>
            </form>
        </div>
    </header>

    <main class="db-main">

        <div class="db-page-head">
            <div>
                <h1 class="db-page-title">Dashboard</h1>
                <p class="db-page-sub">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="success-banner">&#10003; @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="error-banner">&#9888; @TempData["Error"]</div>
        }

        <!-- Stat cards -->
        <section class="db-stats">
            <div class="db-stat-card total">
                <div class="db-stat-value">@total</div>
                <div class="db-stat-label">Total Tasks</div>
            </div>
            <div class="db-stat-card inprogress">
                <div class="db-stat-value">@inProgress</div>
                <div class="db-stat-label">In Progress</div>
            </div>
            <div class="db-stat-card completed">
                <div class="db-stat-value">@completed</div>
                <div class="db-stat-label">Completed</div>
            </div>
            <div class="db-stat-card pending">
                <div class="db-stat-value">@pending</div>
                <div class="db-stat-label">Pending</div>
            </div>
        </section>

        <!-- Task table -->
        <section class="db-table-wrap">
            <div class="db-table-header">
                <div style="display:flex;align-items:center;gap:12px;">
                    <h2 class="db-section-title">All Tasks</h2>
                    <span class="db-task-count">@total tasks</span>
                </div>
                <input class="db-search" id="taskSearch"
                       placeholder="Search title or user…" oninput="filterTable()" />
            </div>

            <div class="db-table-scroll">
                <table class="db-table" id="taskTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th>Assigned To</th>
                            <th>Status</th>
                            <th>Department</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!tasks.Any())
                        {
                            <tr><td colspan="8" class="db-empty">No tasks found.</td></tr>
                        }

                        @foreach (var t in tasks)
                        {
                            var badgeClass = t.Status.ToString() switch
                            {
                                "InProgress" => "badge-inprogress",
                                "Completed" => "badge-completed",
                                _ => "badge-pending"
                            };

                            <tr>
                                <td style="color:#888;font-size:13px;">#@t.Id</td>
                                <td style="font-weight:500;">@t.Title</td>
                                <td>
                                    @if (t.AssignedUsername != null)
                                    {
                                        <span>@t.AssignedUsername</span>
                                    }
                                    else
                                    {

                                        <span style="color:#aaa;font-style:italic;">Unassigned</span>
                                    }
                                </td>
                                <td><span class="db-badge @badgeClass">@t.Status</span></td>
                                <td>@t.DepartmentName</td>
                                <td>@t.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>@t.UpdatedAt.ToString("yyyy-MM-dd")</td>
                                <td style="text-align:center;white-space:nowrap;">

                                    <!-- Subtasks button (existing) -->
                                    <button class="btn-view-subtasks"
                                            onclick="openSubtaskDrawer(@t.Id, '@Html.Raw(t.Title.Replace("'", "\\'"))')">
                                        &#128196; Subtasks
                                    </button>

                                    <!-- NEW: View Comments button -->
                                    <button class="btn-view-comments"
                                            onclick="openTaskCommentDrawer(@t.Id, '@Html.Raw(t.Title.Replace("'", "\\'"))')">
                                        &#128172; Comments
                                    </button>

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

    </main>
</div>

<!-- ── Shared overlay ── -->
<div class="drawer-overlay" id="drawerOverlay" onclick="closeAllDrawers()"></div>

<!-- ── SUBTASK DRAWER (existing) ── -->
<aside class="side-drawer" id="subtaskDrawer" aria-label="Subtasks panel">
    <div class="drawer-head">
        <div>
            <p class="drawer-head-title" id="drawerTitle">Subtasks</p>
            <p class="drawer-head-sub" id="drawerSub">—</p>
        </div>
        <button class="drawer-close" onclick="closeAllDrawers()" aria-label="Close">&#10005;</button>
    </div>
    <div class="drawer-body" id="drawerBody"></div>
</aside>

<!-- ── TASK COMMENTS DRAWER (NEW) ── -->
<aside class="side-drawer" id="taskCommentDrawer" aria-label="Task comments panel">
    <div class="drawer-head-comment">
        <div>
            <p class="drawer-head-title" id="taskCommentDrawerTitle">Task Comments</p>
            <p class="drawer-head-sub" id="taskCommentDrawerSub">—</p>
        </div>
        <button class="drawer-close" onclick="closeAllDrawers()" aria-label="Close">&#10005;</button>
    </div>
    <div class="drawer-body" id="taskCommentDrawerBody"></div>
</aside>

<!-- ── SUBTASK COMMENTS DRAWER (NEW) ── -->
<aside class="side-drawer" id="subtaskCommentDrawer" aria-label="Subtask comments panel">
    <div class="drawer-head-comment">
        <div>
            <p class="drawer-head-title" id="subtaskCommentDrawerTitle">Subtask Comments</p>
            <p class="drawer-head-sub" id="subtaskCommentDrawerSub">—</p>
        </div>
        <button class="drawer-close" onclick="closeAllDrawers()" aria-label="Close">&#10005;</button>
    </div>
    <div class="drawer-body" id="subtaskCommentDrawerBody"></div>
</aside>

@section Scripts {
    <script>
        // ── Table search ──────────────────────────────────────────────────────
        function filterTable() {
            var q    = document.getElementById('taskSearch').value.toLowerCase();
            var rows = document.querySelectorAll('#taskTable tbody tr');
            rows.forEach(function (row) {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }

        // ── Close all drawers ─────────────────────────────────────────────────
        function closeAllDrawers() {
            ['subtaskDrawer','taskCommentDrawer','subtaskCommentDrawer'].forEach(function(id) {
                document.getElementById(id).classList.remove('open');
            });
            document.getElementById('drawerOverlay').classList.remove('open');
            document.body.style.overflow = '';
        }

        function openOverlay() {
            document.getElementById('drawerOverlay').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeAllDrawers();
        });

        // ════════════════════════════════════════════════════════════════════
        //  SUBTASK DRAWER  (existing logic, unchanged except comment button added)
        // ════════════════════════════════════════════════════════════════════

        function openSubtaskDrawer(taskId, taskTitle) {
            closeAllDrawers();
            document.getElementById('drawerTitle').textContent = 'Subtasks';
            document.getElementById('drawerSub').textContent   = taskTitle;
            document.getElementById('drawerBody').innerHTML    = renderLoading('#6c63ff');
            openOverlay();
            document.getElementById('subtaskDrawer').classList.add('open');
            loadSubtasks(taskId);
        }

        async function loadSubtasks(taskId) {
            try {
                var resp = await fetch('/Manager/GetSubtasks?taskId=' + taskId);
                if (!resp.ok) throw new Error('HTTP ' + resp.status);
                var subtasks = await resp.json();
                renderSubtasks(subtasks);
            } catch (err) {
                document.getElementById('drawerBody').innerHTML = renderError(err.message);
            }
        }

        function renderSubtasks(list) {
            if (!list || list.length === 0) {
                document.getElementById('drawerBody').innerHTML =
                    '<div class="drawer-state"><span class="drawer-state-icon">&#128193;</span>'
                    + '<span>No subtasks for this task yet.</span></div>';
                return;
            }

            var html = '<p style="font-size:12px;color:#aaa;margin-bottom:14px;">'
                     + list.length + ' subtask' + (list.length !== 1 ? 's' : '') + '</p>';

            list.forEach(function (s) {
                var dotClass   = statusDotClass(s.status);
                var badgeClass = statusBadgeClass(s.status);
                var label      = statusLabel_(s.status);
                var desc       = s.description && s.description.trim()
                                    ? esc(s.description)
                                    : '<em style="color:#ccc;">No description</em>';
                var assignee   = s.assignedToName
                                    ? '<span class="subtask-assignee">&#128100; ' + esc(s.assignedToName) + '</span>'
                                    : '<span class="subtask-assignee" style="color:#ccc;">Unassigned</span>';

                // NEW: comments button on each subtask card
                var commentBtn = '<button class="btn-subtask-comments" '
                    + 'onclick="openSubtaskCommentDrawer(' + s.id + ', \'' + esc(s.title).replace(/'/g,"\\'") + '\')">'
                    + '&#128172; Comments</button>';

                html +=
                    '<div class="subtask-item">'
                    + '<span class="subtask-dot ' + dotClass + '"></span>'
                    + '<div class="subtask-info">'
                    +   '<div class="subtask-title">' + esc(s.title) + '</div>'
                    +   '<div class="subtask-desc">'  + desc + '</div>'
                    +   '<div class="subtask-meta">'
                    +     '<span class="subtask-badge ' + badgeClass + '">' + label + '</span>'
                    +     assignee
                    +     commentBtn
                    +   '</div>'
                    + '</div>'
                    + '</div>';
            });

            document.getElementById('drawerBody').innerHTML = html;
        }

        // ════════════════════════════════════════════════════════════════════
        //  TASK COMMENTS DRAWER  (NEW)
        // ════════════════════════════════════════════════════════════════════

        function openTaskCommentDrawer(taskId, taskTitle) {
            closeAllDrawers();
            document.getElementById('taskCommentDrawerTitle').textContent = 'Comments';
            document.getElementById('taskCommentDrawerSub').textContent   = taskTitle;
            document.getElementById('taskCommentDrawerBody').innerHTML    = renderLoading('#e67e22');
            openOverlay();
            document.getElementById('taskCommentDrawer').classList.add('open');
            loadTaskComments(taskId);
        }

        async function loadTaskComments(taskId) {
            try {
                var resp = await fetch('/Manager/GetTaskComments?taskId=' + taskId);
                if (!resp.ok) throw new Error('HTTP ' + resp.status);
                var comments = await resp.json();
                renderComments(comments, 'taskCommentDrawerBody');
            } catch (err) {
                document.getElementById('taskCommentDrawerBody').innerHTML = renderError(err.message);
            }
        }

        // ════════════════════════════════════════════════════════════════════
        //  SUBTASK COMMENTS DRAWER  (NEW)
        // ════════════════════════════════════════════════════════════════════

        function openSubtaskCommentDrawer(subtaskId, subtaskTitle) {
            // Keep the subtask drawer open behind — just swap to the comment drawer
            document.getElementById('subtaskDrawer').classList.remove('open');
            document.getElementById('subtaskCommentDrawerTitle').textContent = 'Comments';
            document.getElementById('subtaskCommentDrawerSub').textContent   = subtaskTitle;
            document.getElementById('subtaskCommentDrawerBody').innerHTML    = renderLoading('#e67e22');
            // overlay already open
            document.getElementById('subtaskCommentDrawer').classList.add('open');
            loadSubtaskComments(subtaskId);
        }

        async function loadSubtaskComments(subtaskId) {
            try {
                var resp = await fetch('/Manager/GetSubtaskComments?subtaskId=' + subtaskId);
                if (!resp.ok) throw new Error('HTTP ' + resp.status);
                var comments = await resp.json();
                renderComments(comments, 'subtaskCommentDrawerBody');
            } catch (err) {
                document.getElementById('subtaskCommentDrawerBody').innerHTML = renderError(err.message);
            }
        }

        // ── Shared comment renderer ───────────────────────────────────────────

        function renderComments(list, bodyId) {
            if (!list || list.length === 0) {
                document.getElementById(bodyId).innerHTML =
                    '<div class="drawer-state">'
                    + '<span class="drawer-state-icon">&#128172;</span>'
                    + '<span>No comments yet.</span>'
                    + '</div>';
                return;
            }

            var html = '<p style="font-size:12px;color:#aaa;margin-bottom:14px;">'
                     + list.length + ' comment' + (list.length !== 1 ? 's' : '') + '</p>';

            list.forEach(function (c) {
                var dt = new Date(c.createdAt);
                var formatted = dt.toLocaleDateString(undefined, { year:'numeric', month:'short', day:'numeric' })
                              + ' ' + dt.toLocaleTimeString(undefined, { hour:'2-digit', minute:'2-digit' });

                html += '<div class="comment-card">'
                      + '<div class="comment-author">&#128100; ' + esc(c.authorName) + '</div>'
                      + '<div class="comment-body">' + esc(c.content) + '</div>'
                      + '<div class="comment-time">&#128336; ' + formatted + '</div>'
                      + '</div>';
            });

            document.getElementById(bodyId).innerHTML = html;
        }

        // ── Shared helpers ────────────────────────────────────────────────────

        function renderLoading(ringColor) {
            var style = ringColor ? 'border-top-color:' + ringColor + ';' : '';
            return '<div class="drawer-state"><div class="spin-ring" style="' + style + '"></div>'
                 + '<span>Loading…</span></div>';
        }

        function renderError(msg) {
            return '<div class="drawer-state">'
                 + '<span class="drawer-state-icon">&#9888;</span>'
                 + '<span>Could not load data.</span>'
                 + '<small style="color:#ccc;">' + esc(msg) + '</small>'
                 + '</div>';
        }

        function statusDotClass(s) {
            if (s === 'Completed')  return 'dot-completed';
            if (s === 'InProgress') return 'dot-inprogress';
            return 'dot-pending';
        }

        function statusBadgeClass(s) {
            if (s === 'Completed')  return 'sb-completed';
            if (s === 'InProgress') return 'sb-inprogress';
            return 'sb-pending';
        }

        function statusLabel_(s) {
            if (s === 'InProgress') return 'In Progress';
            return s;
        }

        function esc(str) {
            return String(str)
                .replace(/&/g,'&amp;').replace(/</g,'&lt;')
                .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
    </script>
}