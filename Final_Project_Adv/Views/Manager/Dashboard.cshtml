@using Final_Project_Adv.Domain.DTO
@model Final_Project_Adv.Models.TaskDashboardVm

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tasks = Model?.Tasks ?? new List<TaskDashboardItemDto>();

    var total = tasks.Count;
    var inProgress = tasks.Count(t => t.Status.ToString() == "InProgress");
    var completed = tasks.Count(t => t.Status.ToString() == "Completed");
    var pending = tasks.Count(t => t.Status.ToString() == "Pending");
}
@section Styles {
    <style>
        /* SHELL */
        .db-shell {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        /* TOPBAR */
        .db-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            height: 60px;
            background: #1e1e2d;
            color: #fff;
        }

        .db-topbar-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .db-logo-mark {
            background: #6c63ff;
            color: #fff;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 14px;
        }

        .db-logo-text {
            font-size: 18px;
            font-weight: 600;
            color: #fff;
        }

        .db-nav {
            display: flex;
            gap: 24px;
        }

        .db-nav-link {
            color: #aaa;
            text-decoration: none;
            font-size: 14px;
        }

            .db-nav-link.active, .db-nav-link:hover {
                color: #fff;
            }

        .db-btn-primary {
            background: #6c63ff;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
        }

            .db-btn-primary:hover {
                background: #574fd6;
            }

        /* MAIN */
        .db-main {
            padding: 32px;
        }

        .db-page-head {
            margin-bottom: 24px;
        }

        .db-page-title {
            font-size: 24px;
            font-weight: 700;
            color: #1e1e2d;
            margin: 0;
        }

        .db-page-sub {
            color: #888;
            font-size: 14px;
            margin: 4px 0 0;
        }

        /* STATS */
        .db-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 32px;
        }

        .db-stat-card {
            background: #fff;
            border-radius: 10px;
            padding: 20px 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        }

        .db-stat-value {
            font-size: 32px;
            font-weight: 700;
            color: #1e1e2d;
        }

        .db-stat-label {
            font-size: 13px;
            color: #888;
            margin-top: 4px;
        }

        /* TABLE */
        .db-table-wrap {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
            padding: 24px;
        }

        .db-table-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .db-section-title {
            font-size: 16px;
            font-weight: 600;
            color: #1e1e2d;
            margin: 0;
        }

        .db-task-count {
            font-size: 13px;
            color: #888;
            background: #f0f0f0;
            padding: 3px 10px;
            border-radius: 20px;
        }

        .db-table-scroll {
            overflow-x: auto;
        }

        .db-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

            .db-table thead tr {
                background: #f8f8fb;
            }

            .db-table th {
                padding: 12px 16px;
                text-align: left;
                font-weight: 600;
                color: #555;
                border-bottom: 1px solid #eee;
            }

            .db-table td {
                padding: 12px 16px;
                color: #333;
                border-bottom: 1px solid #f0f0f0;
            }

            .db-table tbody tr:hover {
                background: #fafafa;
            }

        /* BADGE */
        .db-badge {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
            background: #e8e8ff;
            color: #6c63ff;
        }
    </style>
}

<div class="db-shell">

    <!-- TOPBAR -->
    <header class="db-topbar">
        <div class="db-topbar-left">
            <span class="db-logo-mark">TM</span>
            <span class="db-logo-text">TaskFlow</span>
        </div>

        <nav class="db-nav">
            <a href="#" class="db-nav-link active">Dashboard</a>
            <a href="#" class="db-nav-link">Tasks</a>
            <a href="#" class="db-nav-link">Team</a>
        </nav>

        <div class="db-topbar-right">
            <button class="db-btn db-btn-primary">+ New Task</button>
        </div>
    </header>

    <!-- MAIN -->
    <main class="db-main">

        <!-- HEADER -->
        <div class="db-page-head">
            <div>
                <h1 class="db-page-title">Dashboard</h1>
                <p class="db-page-sub">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
            </div>
        </div>

        <!-- STATS -->
        <section class="db-stats">

            <div class="db-stat-card">
                <div class="db-stat-value">@total</div>
                <div class="db-stat-label">Total Tasks</div>
            </div>

            <div class="db-stat-card">
                <div class="db-stat-value">@inProgress</div>
                <div class="db-stat-label">In Progress</div>
            </div>

            <div class="db-stat-card">
                <div class="db-stat-value">@completed</div>
                <div class="db-stat-label">Completed</div>
            </div>

            <div class="db-stat-card">
                <div class="db-stat-value">@pending</div>
                <div class="db-stat-label">Pending</div>
            </div>

        </section>

        <!-- TABLE -->
        <section class="db-table-wrap">

            <div class="db-table-header">
                <h2 class="db-section-title">All Tasks</h2>
                <span class="db-task-count">@total tasks</span>
            </div>

            <div class="db-table-scroll">
                <table class="db-table">

                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th>Assigned User</th>
                            <th>Status</th>
                            <th>Department</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var t in tasks)
                        {
                            <tr>
                                <td>@t.Id</td>

                                <td>@t.Title</td>

                                <td>
                                    @if (t.AssignedUsername != null)
                                    {
                                        @t.AssignedUsername
                                    }
                                    else
                                    {
                                        <span style="color: gray;">Unassigned</span>
                                    }
                                </td>

                                <td>
                                    <span class="db-badge">@t.Status</span>
                                </td>

                                <td>@t.DepartmentName</td>

                                <td>@t.CreatedAt.ToString("yyyy-MM-dd")</td>

                                <td>@t.UpdatedAt.ToString("yyyy-MM-dd")</td>

                                <td>
                                    <a asp-action="Details" asp-route-id="@t.Id">View</a> |
                                    <a asp-action="Edit" asp-route-id="@t.Id">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </section>

    </main>
</div>